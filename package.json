{
	"name": "z8",
	"private": true,
	"pnpm": {
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"@swc/core",
			"esbuild",
			"msgpackr-extract",
			"msw",
			"sharp"
		],
		"overrides": {
			"@hono/node-server": "1.19.13",
			"@types/react": "19.2.8",
			"@types/react-dom": "19.2.3",
			"esbuild": "0.25.12",
			"fast-xml-parser": "5.5.11",
			"brace-expansion@1.1.12": "1.1.13",
			"brace-expansion@2.0.2": "2.0.3",
			"get-uri>basic-ftp": "5.2.1",
			"get-uri": "6.0.5",
			"glob@7.2.3>minimatch": "3.1.2",
			"hono": "4.12.12",
			"lodash": "4.18.1",
			"lodash-es": "4.18.1",
			"minimatch@3.1.5>brace-expansion": "1.1.13",
			"minimatch@5.1.9>brace-expansion": "2.0.3",
			"pako": "1.0.11",
			"tinyglobby": "0.2.16",
			"undici": "7.24.0"
		}
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"test": "turbo test",
		"test:watch": "turbo test:watch",
		"dev:webapp": "turbo dev --filter=webapp",
		"dev:desktop": "turbo dev --filter=desktop",
		"dev:mobile": "turbo dev --filter=mobile",
		"build:webapp": "turbo build --filter=webapp",
		"build:desktop": "turbo build --filter=desktop",
		"build:mobile": "turbo build --filter=mobile",
		"dev:extension": "turbo dev --filter=extension",
		"build:extension": "turbo build --filter=extension",
		"dev:docs": "turbo dev --filter=docs",
		"build:docs": "turbo build --filter=docs",
		"dev:marketing": "turbo dev --filter=marketing",
		"build:marketing": "turbo build --filter=marketing",
		"docker:up": "docker compose -f deploy/compose/docker-compose.yml up -d",
		"docker:down": "docker compose -f deploy/compose/docker-compose.yml down",
		"docker:logs": "docker compose -f deploy/compose/docker-compose.yml logs -f",
		"docker:ps": "docker compose -f deploy/compose/docker-compose.yml ps",
		"docker:build": "docker build -f Dockerfile.webapp -t z8-webapp:latest .",
		"docker:build:webapp": "docker build -f Dockerfile.webapp -t z8-webapp:latest .",
		"docker:build:worker": "docker build -f Dockerfile.worker -t z8-worker:latest .",
		"docker:build:migration": "docker build -f Dockerfile.migration -t z8-migration:latest .",
		"docker:build:seed": "docker build -f Dockerfile.db-seed -t z8-db-seed:latest .",
		"docker:build:all": "docker build -f Dockerfile.webapp -t z8-webapp:latest . && docker build -f Dockerfile.worker -t z8-worker:latest . && docker build -f Dockerfile.migration -t z8-migration:latest . && docker build -f Dockerfile.db-seed -t z8-db-seed:latest .",
		"docker:prod:up": "docker compose -f docker-compose.prod.yml up -d",
		"docker:prod:down": "docker compose -f docker-compose.prod.yml down",
		"docker:prod:logs": "docker compose -f docker-compose.prod.yml logs -f"
	},
	"devDependencies": {
		"@esbuild/win32-x64": "^0.28.0",
		"puppeteer-core": "^24.40.0",
		"shadcn": "^4.2.0",
		"turbo": "^2.9.6"
	},
	"packageManager": "pnpm@10.32.1"
}
