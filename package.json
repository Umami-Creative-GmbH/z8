{
	"name": "z8",
	"private": true,
	"pnpm": {
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"@swc/core",
			"esbuild",
			"msgpackr-extract",
			"msw",
			"sharp"
		],
		"overrides": {
			"@hono/node-server": "1.19.13",
			"@xmldom/xmldom": "0.8.13",
			"@types/react": "19.2.14",
			"@types/react-dom": "19.2.3",
			"dompurify": "3.4.0",
			"esbuild": "0.25.12",
			"effect": "3.21.0",
			"fast-xml-parser": "5.7.0",
			"follow-redirects": "1.16.0",
			"brace-expansion@1.1.12": "1.1.13",
			"brace-expansion@2.0.2": "2.0.3",
			"get-uri>basic-ftp": "5.3.0",
			"get-uri": "6.0.5",
			"glob@7.2.3>minimatch": "3.1.5",
			"hono": "4.12.14",
			"lodash": "4.18.1",
			"lodash-es": "4.18.1",
			"minimatch@3.1.5>brace-expansion": "1.1.13",
			"minimatch@5.1.9>brace-expansion": "2.0.3",
			"pako": "1.0.11",
			"postcss": "8.5.13",
			"protobufjs": "8.0.1",
			"srvx": "0.11.13",
			"tinyglobby": "0.2.16",
			"undici": "7.24.0",
			"uuid": "14.0.0"
		}
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"test": "pnpm node --test docker/scripts/prepare-target-runtime.test.mjs && turbo test",
		"test:watch": "turbo test:watch",
		"dev:webapp": "turbo dev --filter=webapp",
		"dev:desktop": "turbo dev --filter=desktop",
		"dev:mobile": "turbo dev --filter=mobile",
		"build:webapp": "turbo build --filter=webapp",
		"build:desktop": "turbo build --filter=desktop",
		"build:mobile": "turbo build --filter=mobile",
		"dev:extension": "turbo dev --filter=extension",
		"build:extension": "turbo build --filter=extension",
		"dev:docs": "turbo dev --filter=docs",
		"build:docs": "turbo build --filter=docs",
		"dev:marketing": "turbo dev --filter=marketing",
		"build:marketing": "turbo build --filter=marketing",
		"docker:up": "docker compose -f deploy/compose/docker-compose.yml up -d",
		"docker:down": "docker compose -f deploy/compose/docker-compose.yml down",
		"docker:logs": "docker compose -f deploy/compose/docker-compose.yml logs -f",
		"docker:ps": "docker compose -f deploy/compose/docker-compose.yml ps",
		"docker:build": "docker build -f docker/Dockerfile.webapp -t z8-webapp:latest .",
		"docker:build:webapp": "docker build -f docker/Dockerfile.webapp -t z8-webapp:latest .",
		"docker:build:worker": "docker build -f docker/Dockerfile.worker -t z8-worker:latest .",
		"docker:build:migration": "docker build -f docker/Dockerfile.migration -t z8-migration:latest .",
		"docker:build:seed": "docker build -f docker/Dockerfile.db-seed -t z8-db-seed:latest .",
		"docker:build:all": "docker build -f docker/Dockerfile.webapp -t z8-webapp:latest . && docker build -f docker/Dockerfile.worker -t z8-worker:latest . && docker build -f docker/Dockerfile.migration -t z8-migration:latest . && docker build -f docker/Dockerfile.db-seed -t z8-db-seed:latest .",
		"docker:sync:non-web-targets": "pnpm node docker/scripts/prepare-target-runtime.mjs manifest worker && pnpm node docker/scripts/prepare-target-runtime.mjs manifest migration && pnpm node docker/scripts/prepare-target-runtime.mjs manifest db-seed && pnpm --dir docker/targets/worker install --lockfile-only --ignore-workspace && pnpm --dir docker/targets/migration install --lockfile-only --ignore-workspace && pnpm --dir docker/targets/db-seed install --lockfile-only --ignore-workspace",
		"docker:prod:up": "docker compose -f docker-compose.prod.yml up -d",
		"docker:prod:down": "docker compose -f docker-compose.prod.yml down",
		"docker:prod:logs": "docker compose -f docker-compose.prod.yml logs -f"
	},
	"devDependencies": {
		"@esbuild/win32-x64": "^0.28.0",
		"puppeteer-core": "^24.43.0",
		"shadcn": "^4.7.0",
		"turbo": "^2.9.9"
	},
	"packageManager": "pnpm@10.33.2"
}
