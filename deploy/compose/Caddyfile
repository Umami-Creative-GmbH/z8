# Caddy terminates HTTP/HTTPS for the self-hosted Compose stack.
# Configure APP_DOMAIN and DOCS_DOMAIN in the Compose environment.

{$APP_DOMAIN:localhost} {
	encode zstd gzip

	handle /api/notifications/stream {
		reverse_proxy notify-server:3002
	}

	reverse_proxy webapp:3000
}

{$DOCS_DOMAIN:docs.localhost} {
	encode zstd gzip

	reverse_proxy docs:3001
}
