    "dev": "next dev --turbopack",
    "dev:webpack": "next dev",
    "build": "pnpm run generate-licenses && next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "auth:generate": "NODE_OPTIONS='--require=./scripts/register-auth-generate-alias.cjs' pnpm dlx auth@latest generate --config ./src/lib/auth.ts --output ./src/db/auth-schema.ts",
    "auth:migrate": "pnpm run auth:generate && pnpm drizzle-kit push",
    "generate-licenses": "mkdir -p ./src/data && pnpm dlx license-report --only=prod --output=json --config license-report-config.json > ./src/data/licenses.json",
    "db:seed": "tsx src/db/seed/do-seed.ts"
  },
